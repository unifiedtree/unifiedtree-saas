{
  "name": "erp-platform",
  "version": "2.0.0",
  "private": true,
  "description": "Enterprise Modular SaaS ERP Platform — Multi-tenant, Domain-driven Architecture",
  "scripts": {
    "dev": "turbo run dev",
    "dev:website": "turbo run dev --filter=website",
    "dev:platform": "turbo run dev --filter=platform",
    "dev:admin": "turbo run dev --filter=@erp/admin",
    "build": "turbo run build",
    "build:apps": "turbo run build --filter=./apps/*",
    "build:packages": "turbo run build --filter=./packages/*",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean && find . -name node_modules -type d -prune -exec rm -rf '{}' +",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "new-module": "node scripts/generate-module.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
