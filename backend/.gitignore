target/
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz

# Maven
.mvn/
!.mvn/wrapper/
!.mvn/wrapper/maven-wrapper.jar

# IDE
.idea/
*.iml
*.iws
*.ipr
.vscode/
.project
.classpath
.settings/

# Spring Boot
application-local.yml
application-secret.yml

# Env files - never commit (Railway, AWS, JWT secrets etc.)
.env
.env.*
!.env.example

# Keys -- NEVER commit private keys
**/keys/private.pem
**/keys/*.key
**/keys/*.p12
**/keys/*.jks
# public.pem is safe to commit
!**/keys/public.pem

# Logs
*.log
logs/

# Runtime artifacts (pid files, transient Railway scratch files)
*.pid
.railway-*

# OS
.DS_Store
Thumbs.db

# Docker volumes
docker-volumes/

# Test outputs
surefire-reports/
