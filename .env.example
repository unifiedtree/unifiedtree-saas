# Database
DB_URL=jdbc:postgresql://localhost:5432/unifiedtree
DB_USERNAME=nexus
DB_PASSWORD=nexus
# Or use DATABASE_URL directly for Railway/Heroku
# DATABASE_URL=jdbc:postgresql://<user>:<password>@<host>:<port>/<dbname>

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BROKERS=localhost:9092

# JWT
JWT_SECRET=change-me-to-a-256-bit-random-secret-for-production

# Frontend API
VITE_API_URL=http://localhost:8080
VITE_APP_URL=http://localhost:3000

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
S3_BUCKET=unifiedtree
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@unifiedtree.com
# Base URL for invitation / password-reset links in emails. Prod: scheme+domain
# (the tenant subdomain is prepended automatically). Dev defaults to localhost:3001.
INVITE_URL_BASE=https://unifiedtree.com

# Domain
DOMAIN=unifiedtree.com
CORS_ORIGIN_WEBSITE=http://localhost:3000
CORS_ORIGIN_PLATFORM=http://localhost:3001
CORS_ORIGIN_ADMIN=http://localhost:3002
